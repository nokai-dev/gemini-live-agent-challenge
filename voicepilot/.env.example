# VoicePilot Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# GEMINI API CONFIGURATION
# =============================================================================

# Your Google Gemini API Key
# Get one at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Configuration
GEMINI_MODEL=gemini-2.0-flash-live-001
GEMINI_API_REGION=us-central1

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server Port (default: 8080)
PORT=8080

# Server Host (default: 0.0.0.0)
HOST=0.0.0.0

# Node Environment (development, production, test)
NODE_ENV=development

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Backend WebSocket URL for Electron app
# In development: ws://localhost:8080
# In production: wss://your-cloud-run-url.run.app
VITE_BACKEND_URL=ws://localhost:8080

# =============================================================================
# STATIC FILES CONFIGURATION (Production)
# =============================================================================

# Path to built frontend static files
STATIC_FILES_PATH=/app/static

# Path to demo project files
DEMO_PROJECT_PATH=/app/demo-project

# =============================================================================
# OPTIONAL: MONITORING & ANALYTICS
# =============================================================================

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# =============================================================================
# OPTIONAL: FEATURE FLAGS
# =============================================================================

# Enable/disable real Gemini API (use mock responses if false)
USE_REAL_GEMINI_API=false

# Enable/disable voice recording
ENABLE_VOICE_RECORDING=true

# Enable/disable screen capture
ENABLE_SCREEN_CAPTURE=true

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable hot reload for development
HOT_RELOAD=true

# Open DevTools on startup (development only)
OPEN_DEVTOOLS=false