{
  "name": "hackathon-agent-swarm",
  "version": "1.0.0",
  "description": "Multi-agent system for dominating Devpost hackathons",
  "author": "OpenClaw Agent",
  "agents": [
    {
      "id": "jury-scout",
      "name": "Jury Scout",
      "description": "Deep research on jurors, their backgrounds, preferences, past winners",
      "file": "agents/jury-scout.md"
    },
    {
      "id": "bounty-analyst",
      "name": "Bounty Analyst",
      "description": "Extract bounties, generate novel disruptive ideas",
      "file": "agents/bounty-analyst.md"
    },
    {
      "id": "critic",
      "name": "Critic",
      "description": "Validate originality, code review, feasibility",
      "file": "agents/critic.md"
    },
    {
      "id": "coder",
      "name": "Coder",
      "description": "Build MVP, GitHub commits, README",
      "file": "agents/coder.md"
    }
  ],
  "orchestrator": {
    "id": "hackathon-orchestrator",
    "name": "Hackathon Orchestrator",
    "description": "Coordinates the 4-agent swarm for hackathon submissions",
    "file": "orchestrator.md",
    "entryPoint": true
  },
  "workflow": {
    "trigger": "Devpost URL",
    "phases": [
      {
        "name": "Research",
        "parallel": ["jury-scout", "bounty-analyst"]
      },
      {
        "name": "Selection",
        "agent": "critic",
        "input": "Research outputs"
      },
      {
        "name": "Build",
        "agent": "coder",
        "loop": {
          "reviewer": "critic",
          "maxIterations": 3,
          "threshold": 8
        }
      },
      {
        "name": "Deliver",
        "output": "Submission package"
      }
    ]
  }
}
